# ───────────────────────────────────────────────────────────────────
# Speech Translator — real-time speech-to-speech translation pipeline.
# ───────────────────────────────────────────────────────────────────
# NVIDIA GPU required for Whisper STT (the pipeline pins device_ids=['0']).
# nvidia-container-toolkit must be installed on the host.
# ───────────────────────────────────────────────────────────────────

# ── LLM (translation step) ───────────────────────────────────────
# Default points at the bundled Ollama. Pull the model first (see README).
LLM_MODEL=gpt-oss:20b
LLM_BASE_URL=http://demo-ollama:11434/v1
LLM_API_KEY=unused

# ── STT / TTS knobs ──────────────────────────────────────────────
STT_MODEL=openai/whisper-large-v3
TRANSLATE_LANGUAGE=auto
KOKORO_VOICE=af_heart
KOKORO_LANG_CODE=a
KOKORO_DEVICE=cpu

# ── HuggingFace (only needed for gated / first-run downloads) ────
HF_TOKEN=
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0

# ── Host port mappings ────────────────────────────────────────────
APP_PORT=8092
PIPELINE_SEND_PORT=12345
PIPELINE_RECV_PORT=12346
BROADCAST_API_PORT=8088
OLLAMA_HOST_PORT=11434

# ── Optional HTTPS reverse proxy (--profile proxy) ────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
